PORT=8080
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=keepsafe
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Keys
CPSC_API_URL=https://www.cpsc.gov/Recalls
HC_RSS_URL=https://www.canada.ca/en/health-canada/services/consumer-product-safety/advisories-warnings-recalls.xml

# EU Safety Gate (disabled by default)
EU_SAFETY=false
EU_SAFETY_URL=https://ec.europa.eu/safety-gate-alerts/screen/search

# CORS
CORS_ORIGIN=http://localhost:3000